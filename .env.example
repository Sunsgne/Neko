# ── Neko 平台环境变量样例 ──
# 复制为 .env 并按需修改（.env 不入库）。
# 生产部署可直接运行 scripts/deploy-ubuntu.sh，会自动生成带随机密钥的 .env。

# ── API 服务 ──
NEKO_HTTP_ADDR=:8080
NEKO_ENV=development          # development | production
NEKO_LOG_LEVEL=info           # debug | info | warn | error

# 仓储后端：memory（默认，无需 DB）| postgres
NEKO_STORE=memory

# 鉴权与初始账号（生产请改为强密码）
NEKO_AUTH=off                 # off | on（部署脚本会设为 on）
NEKO_ADMIN_EMAIL=admin@neko.io
NEKO_ADMIN_PASSWORD=neko12345
NEKO_SEED=false               # true 时注入演示数据 + 演示账号

# ── PostgreSQL（NEKO_STORE=postgres 时使用）──
POSTGRES_USER=neko
POSTGRES_PASSWORD=neko
POSTGRES_DB=neko
POSTGRES_PORT=5432
DATABASE_URL=postgres://neko:neko@localhost:5432/neko?sslmode=disable

# ── 其他基础设施 ──
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222
VM_URL=http://localhost:8428
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=neko-api

# ── 容器部署端口与对外地址 ──
NEKO_API_PORT=8080
NEKO_WEB_PORT=3000
# 浏览器访问 API 的地址（部署脚本按服务器 IP 自动填充）
NEKO_PUBLIC_API_URL=http://localhost:8080

# 设备凭据静态加密密钥（生产务必设置为强随机值，部署脚本会生成）
NEKO_SECRET_KEY=

# 告警通知渠道（留空则禁用）
NEKO_ALERT_WEBHOOK=
NEKO_DINGTALK_WEBHOOK=
NEKO_WECOM_WEBHOOK=

# ── 前端（本地 npm 开发用）──
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
