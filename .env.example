# ── Neko 平台环境变量样例 ──
# 复制为 .env 并按需修改（.env 不入库）

# API 服务
NEKO_HTTP_ADDR=:8080
NEKO_ENV=development          # development | production
NEKO_LOG_LEVEL=info           # debug | info | warn | error

# 仓储后端：memory（默认，无需 DB）| postgres
NEKO_STORE=memory

# PostgreSQL（NEKO_STORE=postgres 时使用）
DATABASE_URL=postgres://neko:neko@localhost:5432/neko?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# NATS JetStream
NATS_URL=nats://localhost:4222

# VictoriaMetrics
VM_URL=http://localhost:8428

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=neko-api

# 前端
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
